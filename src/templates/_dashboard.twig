{% extends '_layouts/cp' %}

{% do view.registerAssetBundle('convergine\\craftbastion\\assets\\DashboardAssets') %}

{% set plugin = craft.app.getModule('craft-bastion') %}
{% set crumbs = [
    { label: 'Craft Bastion'|t('craft-bastion')  , url: url('craft-bastion') },
] %}
{% set selectedSubnavItem = 'dashboard' %}
{% import "_includes/forms" as forms %}

{% set title = 'Craft Bastion'|t('craft-bastion') %}


{% set securityScanResults = lastSecurityScan ? lastSecurityScan.getResults() : null %}

{% block header %}
{% endblock %}

{% block content %}
    <header class="header">
        <div class="header-left">
            <div class="logo">
                <svg width="25" height="25" viewBox="0 0 230 230" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M209.812 26.1061L209.232 22.3043L206.404 19.802C204.112 17.7761 182.171 0 118.1 0C54.8509 0 26.6944 18.1693 25.5251 18.9456L21.6774 21.4846L20.9912 26.1494C16.4139 57.2534 18.2461 87.1979 26.4412 115.147C33.004 137.528 43.6209 158.622 57.999 177.851C82.4244 210.505 109.188 226.441 110.318 227.104L115.251 230L120.208 227.148C145.5 212.597 165.978 192.895 181.065 168.582C193.075 149.229 201.673 126.988 206.617 102.472C214.978 61.0286 210.028 27.5122 209.812 26.1061ZM167.787 170.218C160.101 168.345 138.924 164.447 105.964 165.933C104.924 170.807 100.72 174.466 95.6998 174.466C89.9032 174.466 85.1828 169.584 85.1828 163.587C85.1828 157.589 89.9032 152.708 95.6998 152.708C100.617 152.708 104.741 156.217 105.89 160.938C140.153 159.399 159.818 163.104 167.573 165.076L168.06 111.218C168.072 110.414 168.124 109.611 168.216 108.813C162.68 107.256 142.815 102.662 105.964 104.324C104.924 109.196 100.72 112.854 95.6998 112.854C89.9032 112.854 85.1828 107.976 85.1828 101.975C85.1828 95.9744 89.9032 91.0963 95.6998 91.0963C100.617 91.0963 104.741 94.6049 105.89 99.3263C142.981 97.6604 162.966 102.142 169.249 103.914C170.834 98.9132 174.003 94.5636 178.277 91.5229L189.357 83.696C189.357 83.696 118.583 68.3689 40.6294 83.696L52.459 91.4795C59.2183 95.9277 63.3125 103.645 63.3125 111.931V131.193C72.3637 129.164 91.4423 126.235 122.567 127.635C123.713 122.913 127.841 119.405 132.754 119.405C138.554 119.405 143.271 124.286 143.271 130.284C143.271 136.281 138.554 141.163 132.754 141.163C127.734 141.163 123.533 137.498 122.49 132.629C90.6661 131.193 71.5209 134.425 63.3125 136.338L63.8522 168.572C41.2823 137.188 21.7241 90.5532 30.9552 27.7354C30.9552 27.7354 57.0662 10.4391 118.086 10.4391C180.279 10.4391 199.831 27.7354 199.831 27.7354C199.831 27.7354 211.927 106.867 167.787 170.218Z" fill="black"/>
                    <path d="M181.57 29.4246C174.667 26.0115 170.909 25.4864 170.909 25.4864V35.1241C170.909 41.0862 165.773 45.6525 160.056 44.7619C155.422 44.0507 151.994 39.943 151.994 35.1241V21.3987L128.449 19.0092V33.0504C128.449 38.4408 124.215 42.8077 118.991 42.8077H117.382C112.159 42.8077 107.925 38.4408 107.925 33.0504V19.0125C101.669 19.0125 83.9793 21.5316 83.9793 21.5316V35.9317C83.9793 40.8303 80.4582 44.9712 75.7477 45.606L75.6145 45.6259C69.9513 46.3903 64.931 41.8406 64.931 35.9483V24.8517C48.6876 27.9623 41.2788 34.157 41.2788 34.157C36.615 52.4554 40.2328 80.3516 40.2328 80.3516C40.2328 80.3516 70.6941 73.233 115.15 73.233C158.84 73.233 189.771 80.3516 189.771 80.3516C189.771 80.3516 191.104 66.7258 191.104 56.2108C191.132 48.8442 190.686 41.4835 189.771 34.1737C189.771 34.1737 185.117 31.1793 181.57 29.4246Z" fill="black"/>
                    <path d="M95.6535 107.72C98.7808 107.72 101.316 105.095 101.316 101.856C101.316 98.6168 98.7808 95.9911 95.6535 95.9911C92.5263 95.9911 89.9912 98.6168 89.9912 101.856C89.9912 105.095 92.5263 107.72 95.6535 107.72Z" fill="black"/>
                    <path d="M95.6535 169.466C98.7808 169.466 101.316 166.84 101.316 163.601C101.316 160.362 98.7808 157.737 95.6535 157.737C92.5263 157.737 89.9912 160.362 89.9912 163.601C89.9912 166.84 92.5263 169.466 95.6535 169.466Z" fill="black"/>
                    <path d="M132.863 136.167C135.99 136.167 138.526 133.542 138.526 130.303C138.526 127.064 135.99 124.438 132.863 124.438C129.736 124.438 127.201 127.064 127.201 130.303C127.201 133.542 129.736 136.167 132.863 136.167Z" fill="black"/>
                </svg>
                <h1>Bastion</h1>
            </div>
        </div>
        <div class="header-right">
            <button id="rerun-checks-btn" class="btn btn-primary" aria-label="Re-run all security checks"
                data-url="{{ actionUrl('craft-bastion/base/security-scan', {siteId: currentSite.id}) }}"
            >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 4V10H7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M23 20V14H17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14L18.36 18.36A9 9 0 0 1 3.51 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                          stroke-linejoin="round"></path>
                </svg>
                {% if securityScanResults %}
                    {{'Re-run checks'|t('craft-bastion')}}
                {%else%}
                    {{'Run checks'|t('craft-bastion')}}
                {% endif %}
                
                
            </button>

            {% if lastSecurityScan %}
            <div class="legend">
                {% if lastSecurityScan.pass == 1 %}
                    <span class="badge badge-pass">{{'Pass'|t('craft-bastion')}}</span>
                {% else %}
                    <span class="badge badge-fail">{{'Fail'|t('craft-bastion')}}</span>
                {% endif %}
                {% if lastSecurityScan.warning == 1 %}
                    <span class="badge badge-warn">{{'Warn'|t('craft-bastion')}}</span>
                {% endif %}

            </div>
            {% endif %}
        </div>
    </header>
    <main class="main">
        <div class="grid">
            <div class="column column-1">
                {% include "craft-bastion/dashboard/_quick_overview.twig" %}
            </div>

            <div class="column column-2">
                {% include "craft-bastion/dashboard/_ssl_block.twig" with {sslData:sslData} %}
            </div>

            <div class="column column-3">
                {% include "craft-bastion/dashboard/_domain_block.twig" with {domainData:domainData} %}
                {% include "craft-bastion/dashboard/_disk_space_block.twig" with {diskSpaceData:diskSpaceData} %}
            </div>

            <div class="full-width-column">
                <!-- Checks Table -->
                <section class="card checks-card">
                    <div class="checks-header">
                        <div class="checks-header-content">
                            <h3>Security Checks</h3>
                            <button class="settings-btn" aria-label="Security Checks Settings" data-settings="security-settings">
                                <svg width="21" height="17" viewBox="0 0 21 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2.77258 0.5V9.72855" stroke="#7B8793" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M17.8165 0.5V8.009" stroke="#7B8793" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M10.2902 0.5V1.71838" stroke="#7B8793" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M2.77257 14.2737C4.02768 14.2737 5.04515 13.2562 5.04515 12.0011C5.04515 10.746 4.02768 9.72852 2.77257 9.72852C1.51747 9.72852 0.5 10.746 0.5 12.0011C0.5 13.2562 1.51747 14.2737 2.77257 14.2737Z" stroke="#7B8793"/>
                                <path d="M9.8927 15.855C9.8927 15.6216 10.0742 15.4402 10.2902 15.4402C10.5148 15.4402 10.6963 15.6216 10.6963 15.855H9.8927ZM9.8927 16.3388V15.855H10.6963V16.3388H9.8927ZM10.6963 16.3388C10.6963 16.5635 10.5148 16.745 10.2902 16.745C10.0742 16.745 9.8927 16.5635 9.8927 16.3388H10.6963Z" fill="#7B8793"/>
                                <path d="M10.2902 6.28953C11.5453 6.28953 12.5628 5.27206 12.5628 4.01696C12.5628 2.76185 11.5453 1.74438 10.2902 1.74438C9.0351 1.74438 8.01764 2.76185 8.01764 4.01696C8.01764 5.27206 9.0351 6.28953 10.2902 6.28953Z" stroke="#7B8793"/>
                                <path d="M17.8165 12.5283C19.0716 12.5283 20.089 11.5108 20.089 10.2557C20.089 9.00062 19.0716 7.98315 17.8165 7.98315C16.5613 7.98315 15.5439 9.00062 15.5439 10.2557C15.5439 11.5108 16.5613 12.5283 17.8165 12.5283Z" stroke="#7B8793"/>
                                <path d="M2.77258 14.5415V16.3388" stroke="#7B8793" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M10.2902 6.80786V16.3388" stroke="#7B8793" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M17.8165 12.5195V16.3388" stroke="#7B8793" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </button>
                        </div>
                        <div class="filter-tabs" role="tablist" aria-label="Filter security checks">
                            <button class="tab-btn active" data-filter="all" role="tab" aria-selected="true">{{'All'|t('craft-bastion')}}</button>
                            <button class="tab-btn" data-filter="passed" role="tab" aria-selected="false">{{'Passed'|t('craft-bastion')}}</button>
                            <button class="tab-btn" data-filter="warning" role="tab" aria-selected="false">{{'Warning'|t('craft-bastion')}}</button>
                            <button class="tab-btn" data-filter="failed" role="tab" aria-selected="false">{{'Failed'|t('craft-bastion')}}</button>
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="checks-table">
                            <thead>
                            <tr>
                                <th>{{'Status'|t('craft-bastion')}}</th>
                                <th>{{'Check'|t('craft-bastion')}}</th>
                                <th>{{'Details'|t('craft-bastion')}}</th>
                                <th>{{'Action'|t('craft-bastion')}}</th>
                                <th>{{'Info'|t('craft-bastion')}}</th>
                            </tr>
                            </thead>
                            <tbody id="checks-tbody">
                            {% for res in securityScanResults %}

                                <tr class="check-row" data-status="{{ res.status }}">
                                    <td>
                                        <div class="status-icon status-{{ res.status }}">

                                        </div>
                                    </td>
                                    <td>{{ res.name|t('craft-bastion') }}</td>

                                    <td>
                                        {{ res.description|t('craft-bastion')|raw }}

                                        {% if res.info is defined and res.info %}
                                            <span class="info">{{ res.info|t('craft-bastion')|nl2br }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if res.fixUrl is defined and res.fixUrl %}
                                            <a class="btn btn-fix" target="_blank" href="{{ res.fixUrl }}">{{'Fix'|t('craft-bastion')}}</a>
                                        {% endif %}
                                        {% if res.fixText is defined and res.fixText %}
                                            <span class="info-fix"><span class="info">{{ res.fixText|raw }}</span></span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if res.link is defined and res.link|length %}
                                            <a class="" target="_blank" href="{{ res.link.url }}">{{ res.link.label }}</a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                            
                            </tbody>
                        </table>
                    </div>
                </section>

        
            </div>
        </div>
    </main>
    <div class="toast-container" id="toast-container">
        <!-- Toasts will be dynamically added here -->
    </div>
{% endblock %}

{% js %}
{# language=JavaScript #}
    window.dashboard = new BastionDashboard();
    window.dashboard.init();
{% endjs %}
