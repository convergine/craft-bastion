{% extends '_layouts/cp' %}
{% do view.registerAssetBundle('convergine\\craftbastion\\assets\\DaAssets') %}

{% set plugin = craft.app.getModule('craft-bastion') %}
{% set crumbs = [
    { label: 'Dependency Audit'|t('craft-bastion')  , url: url('craft-bastion') },
] %}
{% set selectedSubnavItem = 'dependency-audit' %}
{% import "_includes/forms" as forms %}

{% set title = 'Dependency Audit'|t('craft-bastion') %}

{% set hasVulnerabilities = stats and stats.vulnerable > 0 %}
{% set totalAdvisories = stats ? stats.advisories : 0 %}

{% block header %}
{% endblock %}

{% block content %}
    <div class="cp-layout">

  <!-- Main content -->
  <div class="cp-main">
    <div class="page-header">
      <div>
        <h1>{{'Dependency Audit'|t('craft-bastion')}}</h1>
        <div class="subtitle">{{'Checks installed Composer packages against the Packagist Security Advisories database.'|t('craft-bastion')}}</div>
      </div>
      <button class="btn-scan">
        
        {{'Run Scan'|t('craft-bastion')}}
      </button>
    </div>

    {% if lastScan %}
      <!-- Scan metadata -->
      <div class="scan-meta">
        <span><span class="dot {{ hasVulnerabilities ? '' : 'clear' }}"></span></span>
        <span>{{'Last scanned: {date} at {time}'|t('craft-bastion',{date:lastScan.dateCreated|date('M j, Y'),time:lastScan.dateCreated|date('g:i A')})}}</span>
        <span>·</span>
        <span>{{ stats.total }} {{'packages checked'|t('craft-bastion')}}</span>
        <span>·</span>
        <span>{{'Scan took'|t('craft-bastion')}} {{ scanDuration|number_format(1) }}s</span>
      </div>

      <!-- Summary Strip -->
      <div class="summary-strip">
        <div class="summary-card packages">
          <div class="number">{{ stats.total }}</div>
          <div class="label">{{'Packages Scanned'|t('craft-bastion')}}</div>
        </div>
        <div class="summary-card total">
          <div class="number" {% if not hasVulnerabilities %}style="color: var(--craft-green);"{% endif %}>{{ totalAdvisories }}</div>
          <div class="label">{{'Vulnerabilities'|t('craft-bastion')}}</div>
        </div>
        <div class="summary-card critical">
          <div class="number">{{ stats.critical }}</div>
          <div class="label">{{'Critical'|t('craft-bastion')}}</div>
        </div>
        <div class="summary-card high">
          <div class="number">{{ stats.high }}</div>
          <div class="label">{{'High'|t('craft-bastion')}}</div>
        </div>
        <div class="summary-card medium">
          <div class="number">{{ stats.medium }}</div>
          <div class="label">{{'Medium'|t('craft-bastion')}}</div>
        </div>
        <div class="summary-card low">
          <div class="number">{{ stats.low }}</div>
          <div class="label">{{'Low'|t('craft-bastion')}}</div>
        </div>
      </div>

      {% if hasVulnerabilities %}
        <!-- CRITICAL -->
        {% if summary.critical|length > 0 %}
        <div class="severity-group">
          <div class="severity-group-header">
            <span class="severity-badge critical">{{'Critical'|t('craft-bastion')}}</span>
            <span class="count">{{ summary.critical|length }} {{ summary.critical|length == 1 ? 'advisory' : 'advisories' }}</span>
          </div>

          {% for advisory in summary.critical %}
          <div class="advisory-card critical">
            <div class="advisory-top">
              <div class="advisory-title">{{ advisory.title }}</div>
              {% if advisory.cve %}
                <a class="advisory-cve" href="https://cve.mitre.org/cgi-bin/cvename.cgi?name={{ advisory.cve }}" target="_blank">{{ advisory.cve }}</a>
              {% endif %}
            </div>
            <div class="advisory-meta">
              <span><span class="key">{{'Package:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.package }}</span></span>
              <span><span class="key">{{'Installed:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.installedVersion }}</span></span>
              <span><span class="key">{{'Affected:'|t('craft-bastion')}} </span><span class="val affected">{{ advisory.affectedVersions }}</span></span>
              {% if advisory.reportedAt %}
                <span><span class="key">{{'Reported:'|t('craft-bastion')}} </span><span class="val">{{ advisory.reportedAt|date('M j, Y') }}</span></span>
              {% endif %}
            </div>
            {% if advisory.sources|length > 0 %}
            <div class="advisory-source">
              {{'Source:'|t('craft-bastion')}}
              {% for source in advisory.sources %}
                {% set sourceUrl = source is iterable ? (source.url ?? source|first) : source %}
                {% set sourceName = sourceUrl|split('/')|last %}
                <a href="{{ sourceUrl }}" target="_blank">{{ sourceName }}</a>{% if not loop.last %} · {% endif %}
              {% endfor %}
            </div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
        {% endif %}

        <!-- HIGH -->
        {% if summary.high|length > 0 %}
        <div class="severity-group">
          <div class="severity-group-header">
            <span class="severity-badge high">{{'High'|t('craft-bastion')}}</span>
            <span class="count">{{ summary.high|length }} {{ summary.high|length == 1 ? 'advisory' : 'advisories' }}</span>
          </div>

          {% for advisory in summary.high %}
          <div class="advisory-card high">
            <div class="advisory-top">
              <div class="advisory-title">{{ advisory.title }}</div>
              {% if advisory.cve %}
                <a class="advisory-cve" href="https://cve.mitre.org/cgi-bin/cvename.cgi?name={{ advisory.cve }}" target="_blank">{{ advisory.cve }}</a>
              {% endif %}
            </div>
            <div class="advisory-meta">
              <span><span class="key">{{'Package:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.package }}</span></span>
              <span><span class="key">{{'Installed:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.installedVersion }}</span></span>
              <span><span class="key">{{'Affected:'|t('craft-bastion')}} </span><span class="val affected">{{ advisory.affectedVersions }}</span></span>
              {% if advisory.reportedAt %}
                <span><span class="key">{{'Reported:'|t('craft-bastion')}} </span><span class="val">{{ advisory.reportedAt|date('M j, Y') }}</span></span>
              {% endif %}
            </div>
            {% if advisory.sources|length > 0 %}
            <div class="advisory-source">
              Source:
              {% for source in advisory.sources %}
                {% set sourceUrl = source is iterable ? (source.url ?? source|first) : source %}
                {% set sourceName = sourceUrl|split('/')|last %}
                <a href="{{ sourceUrl }}" target="_blank">{{ sourceName }}</a>{% if not loop.last %} · {% endif %}
              {% endfor %}
            </div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
        {% endif %}

        <!-- MEDIUM -->
        {% if summary.medium|length > 0 %}
        <div class="severity-group">
          <div class="severity-group-header">
            <span class="severity-badge medium">{{'Medium'|t('craft-bastion')}}</span>
            <span class="count">{{ summary.medium|length }} {{ summary.medium|length == 1 ? 'advisory' : 'advisories' }}</span>
          </div>

          {% for advisory in summary.medium %}
          <div class="advisory-card medium">
            <div class="advisory-top">
              <div class="advisory-title">{{ advisory.title }}</div>
              {% if advisory.cve %}
                <a class="advisory-cve" href="https://cve.mitre.org/cgi-bin/cvename.cgi?name={{ advisory.cve }}" target="_blank">{{ advisory.cve }}</a>
              {% endif %}
            </div>
            <div class="advisory-meta">
              <span><span class="key">{{'Package:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.package }}</span></span>
              <span><span class="key">{{'Installed:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.installedVersion }}</span></span>
              <span><span class="key">{{'Affected:'|t('craft-bastion')}} </span><span class="val affected">{{ advisory.affectedVersions }}</span></span>
              {% if advisory.reportedAt %}
                <span><span class="key">{{'Reported:'|t('craft-bastion')}} </span><span class="val">{{ advisory.reportedAt|date('M j, Y') }}</span></span>
              {% endif %}
            </div>
            {% if advisory.sources|length > 0 %}
            <div class="advisory-source">
              Source:
              {% for source in advisory.sources %}
                {% set sourceUrl = source is iterable ? (source.url ?? source|first) : source %}
                {% set sourceName = sourceUrl|split('/')|last %}
                <a href="{{ sourceUrl }}" target="_blank">{{ sourceName }}</a>{% if not loop.last %} · {% endif %}
              {% endfor %}
            </div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
        {% endif %}

        <!-- LOW -->
        {% if summary.low|length > 0 %}
        <div class="severity-group">
          <div class="severity-group-header">
            <span class="severity-badge low">{{'Low'|t('craft-bastion')}}</span>
            <span class="count">{{ summary.low|length }} {{ summary.low|length == 1 ? 'advisory' : 'advisories' }}</span>
          </div>

          {% for advisory in summary.low %}
          <div class="advisory-card low">
            <div class="advisory-top">
              <div class="advisory-title">{{ advisory.title }}</div>
              {% if advisory.cve %}
                <a class="advisory-cve" href="https://cve.mitre.org/cgi-bin/cvename.cgi?name={{ advisory.cve }}" target="_blank">{{ advisory.cve }}</a>
              {% endif %}
            </div>
            <div class="advisory-meta">
              <span><span class="key">{{'Package:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.package }}</span></span>
              <span><span class="key">{{'Installed:'|t('craft-bastion')}} </span><span class="val pkg">{{ advisory.installedVersion }}</span></span>
              <span><span class="key">{{'Affected:'|t('craft-bastion')}} </span><span class="val affected">{{ advisory.affectedVersions }}</span></span>
              {% if advisory.reportedAt %}
                <span><span class="key">{{'Reported:'|t('craft-bastion')}} </span><span class="val">{{ advisory.reportedAt|date('M j, Y') }}</span></span>
              {% endif %}
            </div>
            {% if advisory.sources|length > 0 %}
            <div class="advisory-source">
              Source:
              {% for source in advisory.sources %}
                {% set sourceUrl = source is iterable ? (source.url ?? source|first) : source %}
                {% set sourceName = sourceUrl|split('/')|last %}
                <a href="{{ sourceUrl }}" target="_blank">{{ sourceName }}</a>{% if not loop.last %} · {% endif %}
              {% endfor %}
            </div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
        {% endif %}

      {% else %}
        <!-- All Clear State -->
        <div class="all-clear">
          <div class="icon">✅</div>
          <h3>{{'All Clear — No Known Vulnerabilities'|t('craft-bastion')}}</h3>
          <p>{{'All {stats_total} installed Composer packages were checked against the Packagist Security Advisories database. No known CVEs affect your currently installed versions.'|t('craft-bastion',{stats_total:stats.total})}}</p>
        </div>
      {% endif %}

    {% else %}
      <!-- No scan yet -->
      <div class="all-clear">
        <div class="icon">🔍</div>
        <h3>{{'No Scan Results Available'|t('craft-bastion')}}</h3>
        <p>{{'Click "Run Scan" to check your Composer packages for known security vulnerabilities.'|t('craft-bastion')}}</p>
      </div>
    {% endif %}

  </div>
</div>
{% endblock %}

{% js %}
{# language=JavaScript #}
    var dependencyAudit = new DependencyAudit();
    dependencyAudit.init();
{% endjs %}
