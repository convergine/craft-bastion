.429H14.919C15.4425 13.182 15.7319 11.8646 15.7828 10.489H19.1019C19.0262 11.9129 18.622 13.2509 17.9642 14.429Z" fill="#0F766E"/>
                        </g>
                        <defs>
                            <clipPath id="clip0_7_15">
                                <rect width="20" height="20" fill="white"/>
                            </clipPath>
                        </defs>
                    </svg>
<span>{{ domainData.domain }}</span></div>
            {% if domainData.isLocal %}

                <div class="domain-details">
                    <div class="warning">{{ "Local development domain detected - can't run check"|t('craft-bastion') }}</div>
                </div>
            {% elseif domainData.isNeverRun %}
                
                <div class="domain-details">
                    <div><label>{{ 'Expires'|t('craft-bastion') }}</label> <span id="expiry-date">--</span></div>
                    <div><label>{{ 'Renew at'|t('craft-bastion') }}</label> <span id="registrar">--</span></div>
                </div>
            {% else %}
                <div class="{% if domainData.expDate == null %} hidden{% endif %}">
                
                    <div class="domain-details ">
                        <div><label>{{ 'Expires'|t('craft-bastion') }}</label> 
                            <span id="expiry-date">
                            {% if domainData.expDate != null %}
                                
                                {{'<b>{expDate}</b> in <b>{expDays}</b> days'|t('craft-bastion',{expDate:domainData.expDate,expDays:domainData.remainData.days})|raw}}
                            {% else %}
                                n/a
                            {%endif%}
                            </span></div>
                        <div><label>{{ 'Renew at'|t('craft-bastion') }} <span id="registrar">
                            {% if domainData.registrantLink %}
                                <a href="{{ domainData.registrantLink }}" target="_blank">{{ domainData.registrant }}</a>
                            {% else %}
                                {{ domainData.registrant!=''?domainData.registrant:'--' }}
                            {% endif %}
                        </span></div>
                    </div>
                </div>
            {% endif %}

        </div>
        <button class="btn btn-secondary" id="domain-check-btn" aria-label="Check Domain">{{ 'Check Domain'|t('craft-bastion') }}</button>
    </div>
</section>