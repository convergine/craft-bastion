        </svg>
        </button>
    </div>
    <div class="card-content">
        <div class="domain-info {{statusClass}}" id="domain-info">
            <div class="domain-name" id="domain-name">                    
            <svg width="20" height="20" viewbox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
